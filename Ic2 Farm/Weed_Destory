local Farm_Func = require("Farm_Func")
local Robot_Func = require("Robot_Func")
local Station_Func = require("Station_Func")
local rb = require("robot")
local config = require("Configs")
function ForwardScanWeed(x)
    local num = 0
    Farm_Func.DestroyWeed()
    repeat
        rb.forward()
        Farm_Func.DestroyWeed()
        num = num + 1
    until num == x
end
while true do
    local num = 0
    local Data = Farm_Func.FarmSize()
    Robot_Func.Moveto(config.FarmPos1[1],config.FarmPos1[3])
    repeat
        ForwardScanWeed(Data[2])
        rb.turnLeft()
        Robot_Func.Forward(1)
        rb.turnLeft()
        ForwardScanWeed(Data[2])
        rb.turnRight()
        Robot_Func.Forward(2)
        rb.turnRight()
        num = num + 1
    until(num == config.Plotwide)
    Station_Func.MovetoCharger()
    Station_Func.FillCropstick()
    Station_Func.StoreItem()
end