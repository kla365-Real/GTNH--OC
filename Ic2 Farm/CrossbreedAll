local config = require("Configs")
local Robot_Func = require("Robot_Func")
local Crossbreed = require("Crossbreed")
local Storage_Func = require("Storage_Func")
local Station_Func = require("Station_Func")
local Data = Storage_Func.StorageSize()
slot = 0
repeat
    local num = 0
    Robot_Func.Moveto(config.FarmPos1[1],config.FarmPos1[3])
    repeat
        num = num + 1
        Crossbreed.PlotCrossbreed()
    until(config.Plotwide == num)
    Station_Func.MovetoCharger()
    Station_Func.FillCropstick()
    Station_Func.StoreItem()
until(slot == Data[1]*Data[2])