local component = require("component")
local rb = require("robot")
local navi = component.navigation
function Forward(x)
    local num = 0
    repeat
        rb.forward()
        num = num + 1
    until num == x
end
function Backward(x)
    local num = 0
    repeat
        rb.back()
        num = num - 1
    until num == x
end
function GetPosition()
    local Data = {}
    local num = 0
    navi.getPosition()
    for x,y in navi.getPosition() do
        num = num +1
        Data[num] = y
    end
    return(Data)
end
function Abs(x)
    if x <= 0 then
        return(x)
    elseif x >= 0 then
        return(-x)
    end
end
function Moveto(x,z)
    local Data = {}
    GetPosition()
    local xaxis = x - Data[1]
    local zaxis = z - Data[3]
    if xaxis >= 0 then
        return(Forward(xaxis))
    elseif xaxis <= 0 then
        return(Backward(xaxis))
    end
    if zaxis >= 0 then
        rb.turnRight()
        Forward(zaxis)
    elseif zaxis <= 0 then
        rb.turnLeft()
        local S = Abs(zaxis)
        Forward(S)
    end 
end
